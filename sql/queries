# task 1.1
Umsatz, Anzahl der Bestellungen und durchschnittlicher Rechnungsbetrag nach Region und Jahr
Виручка, кількість замовлень і середній чек по регіону і року
(Ziel: Aufzeigen, wie das Geschäft im Zeit- und regionalen Vergleich wächst )
(Мета: показати, як бізнес росте в розрізі регіон × рік )

SELECT c.region,
       o.order_year,
       ROUND(SUM(o.net_amount), 2)  AS total_net_revenue,
       COUNT(o.order_id)            AS order_count,
       ROUND(AVG(o.net_amount), 2)  AS avg_order_value
FROM orders o
JOIN customers c ON o.customer_id = c.customer_id
GROUP BY c.region, o.order_year
ORDER BY c.region, o.order_year;


# task 1.2
Die Top 10 der Kunden nach Gesamtausgaben
Топ-10 клієнтів за загальною сумою витрат
(Ziel: Die wertvollsten Kunden für Frage 9 (Top 5 %) zu ermitteln 
und herauszufinden, woher sie kommen (Akquisitionskanal) – als Grundlage 
für die Bindung von VIP-Kunden.)
(Мета: знайти найцінніших клієнтів для питання 9 (топ-5%) і зрозуміти, звідки вони прийшли
(канал залучення) — основа для утримання VIP-клієнтів.)


SELECT o.customer_id,
       c.region,
       c.acquisition_chan,
       COUNT(o.order_id)           AS orders_count,
       ROUND(SUM(o.net_amount),2)  AS total_spent
FROM orders o
JOIN customers c ON o.customer_id = c.customer_id
GROUP BY o.customer_id, c.region, c.acquisition_chan
ORDER BY total_spent DESC
LIMIT 10;

# task 1.3
Umsatz, Marge und Rückgabequote nach Kategorien
Виручка, маржа і частка повернень по категоріях
(Ziel: herauszufinden, welche Kategorie den Umsatz und welche den tatsächlichen Gewinn ausmacht. )
(Мета: побачити, яка категорія дає обсяг, а яка — реальний прибуток. )


WITH cat_orders AS (
    SELECT DISTINCT oi.category, oi.order_id, o.is_returned
    FROM order_items oi
    JOIN orders o ON oi.order_id = o.order_id
)
SELECT oi.category,
       ROUND(SUM(oi.line_total), 2)   AS total_revenue,
       ROUND(AVG(p.margin_pct), 2)    AS avg_margin_pct,
       (SELECT ROUND(100.0 * SUM(is_returned) / COUNT(*), 2)
        FROM cat_orders co WHERE co.category = oi.category)  AS return_rate_pct
FROM order_items oi
JOIN products p ON oi.product_id = p.product_id
GROUP BY oi.category
ORDER BY total_revenue DESC;

# task 1.4
Kunden mit überdurchschnittlichen Ausgaben (Unterabfrage)
Клієнти з витратами вище середнього (підзапит)
(Ziel: zu überprüfen, inwieweit der Umsatz des Unternehmens von einer Minderheit
von Kunden abhängt, die mehr ausgeben als ein „typischer“ Kunde.)
(Мета: перевірити, наскільки виручка компанії залежить від меншості клієнтів,
які витрачають більше за "типового" клієнта.

WITH customer_totals AS (
    SELECT 
        customer_id,
        SUM(net_amount) AS total_spent
    FROM orders
    GROUP BY customer_id
),
avg_spending AS (
    SELECT AVG(total_spent) AS avg_total_spent
    FROM customer_totals
),
above_avg AS (
    SELECT *
    FROM customer_totals ct
    CROSS JOIN avg_spending a
    WHERE ct.total_spent > a.avg_total_spent
)

SELECT
    COUNT(*) AS above_avg_customers,
    ROUND(SUM(total_spent), 2) AS above_avg_total_revenue,

    -- Gesamtumsatz aller Kunden  -- -- Загальний обсяг продажів усіх клієнтів
    (SELECT SUM(total_spent) FROM customer_totals) AS grand_total_revenue,

    -- Umsatzanteil   -- Частка у виручці
    ROUND(
        SUM(total_spent) * 100.0 /
        (SELECT SUM(total_spent) FROM customer_totals)
    , 2) AS share_of_revenue_pct,

    -- Gesamtzahl der Kunden    -- -- Загальна кількість клієнтів
    (SELECT COUNT(*) FROM customer_totals) AS total_customers,

     -- Kundenanteil    -- Частка клієнтів
    ROUND(
        COUNT(*) * 100.0 /
        (SELECT COUNT(*) FROM customer_totals)
    , 2) AS share_of_customers_pct
FROM above_avg;

# task 1.5
ROI der Marketingkanäle
ROI маркетингових каналів
(Ziel: Ermittlung, welcher Marketingkanal das Budget am effektivsten in Umsatz umwandelt )
(Мета: порахувати, який маркетинговий канал ефективніше перетворює бюджет на виручку )

SELECT channel,
       ROUND(SUM(budget), 2)                            AS total_budget,
       ROUND(SUM(attributed_reven), 2)                AS total_attributed_revenue,
       ROUND(SUM(attributed_reven) / SUM(budget), 2)   AS roi
FROM marketing
GROUP BY channel
ORDER BY roi DESC;
